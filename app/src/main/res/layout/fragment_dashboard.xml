<?xml version="1.0" encoding="utf-8"?>
<!-- ══════════════════════════════════════════════════════════
     DASHBOARD — The heart of the app
     Layout from top to bottom:
       1. Weather/AQI card (dark gradient, shows current air quality)
       2. Avatar zone (large cartoon image, name, HP bar, stats)
       3. Recommendations list (scrollable alert cards)
     ══════════════════════════════════════════════════════════ -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_margin">

        <!-- ═══ 1. WEATHER / AQI CARD ═══
             Dark gradient card showing current conditions.
             Left: AQI circle with number. Right: temperature + weather icon. -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWeather"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="@dimen/card_elevation"
            android:layout_marginBottom="@dimen/spacing_md">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_weather_card"
                android:padding="@dimen/card_padding">

                <!-- AQI circle: colored circle with number in center -->
                <FrameLayout
                    android:id="@+id/frameAqi"
                    android:layout_width="@dimen/aqi_circle_size"
                    android:layout_height="@dimen/aqi_circle_size"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <View
                        android:id="@+id/viewAqiCircle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_aqi_circle" />

                    <TextView
                        android:id="@+id/tvAqiNumber"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="2"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-bold"
                        android:textColor="@color/text_on_dark" />
                </FrameLayout>

                <!-- AQI label under the circle -->
                <TextView
                    android:id="@+id/tvAqiLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/aqi_label"
                    android:textSize="11sp"
                    android:textColor="@color/text_on_dark_secondary"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/frameAqi"
                    app:layout_constraintStart_toStartOf="@id/frameAqi"
                    app:layout_constraintEnd_toEndOf="@id/frameAqi" />

                <!-- Air quality text description -->
                <TextView
                    android:id="@+id/tvAirQuality"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/air_quality_good"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_on_dark"
                    android:layout_marginStart="@dimen/spacing_md"
                    app:layout_constraintStart_toEndOf="@id/frameAqi"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvTemperature" />

                <!-- Location name -->
                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Near Castellana station"
                    android:textSize="12sp"
                    android:textColor="@color/text_on_dark_secondary"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_marginTop="2dp"
                    app:layout_constraintStart_toEndOf="@id/frameAqi"
                    app:layout_constraintTop_toBottomOf="@id/tvAirQuality"
                    app:layout_constraintEnd_toStartOf="@id/tvTemperature" />

                <!-- Temperature (large number, right side) -->
                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="23°C"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-light"
                    android:textColor="@color/text_on_dark"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Weather icon (sun, cloud, rain) -->
                <ImageView
                    android:id="@+id/ivWeatherIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/aqi_moderate"
                    android:contentDescription="Weather icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTemperature"
                    android:layout_marginTop="2dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>


        <!-- ═══ 2. AVATAR ZONE ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_md">

            <!-- Avatar image (large, centered) -->
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="@dimen/avatar_large"
                android:layout_height="@dimen/avatar_large"
                android:src="@android:drawable/ic_menu_myplaces"
                android:scaleType="fitCenter"
                android:contentDescription="Your avatar" />

            <!-- Nickname -->
            <TextView
                android:id="@+id/tvNickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Green Rider"
                android:textSize="22sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- HP Bar -->
            <FrameLayout
                android:layout_width="220dp"
                android:layout_height="@dimen/hp_bar_height"
                android:layout_marginTop="@dimen/spacing_sm">

                <!-- Background track (grey) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hp_bar_track" />

                <!-- Colored fill (width set programmatically as % of HP) -->
                <View
                    android:id="@+id/viewHpFill"
                    android:layout_width="160dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hp_bar_fill" />
            </FrameLayout>

            <!-- HP number + stats line -->
            <TextView
                android:id="@+id/tvHpValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="73/100 HP"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/accent"
                android:layout_marginTop="@dimen/spacing_xs" />

            <TextView
                android:id="@+id/tvStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day 5 · 12 stations visited"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>


        <!-- ═══ 3. RECOMMENDATIONS ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/latest_alerts"
            style="@style/AirBusSectionTitle"
            android:layout_marginTop="@dimen/spacing_sm" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecommendations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

        <!-- Shown when there are no alerts -->
        <TextView
            android:id="@+id/tvNoAlerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_alerts"
            android:textSize="14sp"
            android:textColor="@color/text_hint"
            android:textAlignment="center"
            android:padding="@dimen/spacing_lg"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
