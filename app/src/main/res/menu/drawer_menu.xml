<?xml version="1.0" encoding="utf-8"?>
<!-- ══════════════════════════════════════════════════════════
     Navigation Drawer Menu
     Contains items that are NOT in the Bottom Nav:
     Settings, About, and Logout.
     Accessible via hamburger icon or swipe from left edge.
     ══════════════════════════════════════════════════════════ -->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <group android:checkableBehavior="none">

        <item
            android:id="@+id/drawer_settings"
            android:icon="@android:drawable/ic_menu_preferences"
            android:title="@string/nav_settings" />

        <item
            android:id="@+id/drawer_create_character"
            android:icon="@android:drawable/ic_menu_add"
            android:title="@string/btn_create_character" />

    </group>

    <!-- Separator line before destructive action -->
    <group android:checkableBehavior="none">
        <item
            android:id="@+id/drawer_logout"
            android:icon="@android:drawable/ic_lock_power_off"
            android:title="@string/nav_logout" />
    </group>

</menu>
