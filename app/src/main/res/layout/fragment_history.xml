<?xml version="1.0" encoding="utf-8"?>
<!-- ══════════════════════════════════════════════════════════
     HISTORY FRAGMENT (GPS Coordinates List)
     ListView with CSV coordinates data.
     Each item shows one GPS record: timestamp;lat;lon;alt
     ══════════════════════════════════════════════════════════ -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ListView
        android:id="@+id/lvCoordinates"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/screen_margin"
        android:clipToPadding="false"
        android:divider="@color/divider"
        android:dividerHeight="1dp" />

    <!-- Empty state: shown when no GPS data exists yet -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/text_hint"
            android:contentDescription="No GPS data" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No GPS data yet.\nEnable location tracking to record coordinates."
            android:textSize="14sp"
            android:textColor="@color/text_hint"
            android:textAlignment="center"
            android:layout_marginTop="@dimen/spacing_md" />
    </LinearLayout>

</FrameLayout>