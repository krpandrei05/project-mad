<?xml version="1.0" encoding="utf-8"?>
<!-- ══════════════════════════════════════════════════════════
     ITEM: Character card (History / Game Record list)
     Left: circular avatar thumbnail (56dp)
     Center: name (bold) + stats line (day / HP / stations)
     Right: ALIVE (green badge) or DEAD (red badge)
     Dead characters have reduced opacity (set in code: itemView.alpha = 0.7f)
     ══════════════════════════════════════════════════════════ -->
<androidx.cardview.widget.CardView
    android:descendantFocusability="blocksDescendants"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/card_padding">

        <!-- Avatar thumbnail (circular) -->
        <ImageView
            android:id="@+id/ivCharacterAvatar"
            android:layout_width="@dimen/avatar_small"
            android:layout_height="@dimen/avatar_small"
            android:src="@android:drawable/ic_menu_myplaces"
            android:scaleType="centerCrop"
            android:contentDescription="Character avatar" />

        <!-- Name + stats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_md">

            <TextView
                android:id="@+id/tvCharacterName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Green Rider"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvCharacterStats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Day 12 · HP: 73/100 · 28 stations"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvCharacterDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Created Mar 15, 2026"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Status badge: ALIVE or DEAD -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvCharacterStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_alive"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/text_on_dark"
                android:background="@drawable/bg_badge_alive"
                android:textAllCaps="true" />

            <Button
                android:id="@+id/btnSelectCharacter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_play"
                android:textSize="11sp"
                android:layout_marginTop="6dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
