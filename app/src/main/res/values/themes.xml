<resources>
    <!--  ══════════════════════════════════════════════════════════
             AirBus Quest — App Theme
             Based on Material Components with hybrid light/dark style:
               • Dark Toolbar + Bottom Nav (primary = forest night)
               • Light content area (background = warm white)
             ══════════════════════════════════════════════════════════  -->
    <style name="Theme.AirBusQuest" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!--  We use NoActionBar because we define our own Toolbar in each layout.
                     This gives us full control over the toolbar appearance.  -->
        <!--  Primary colors: dark forest green for Toolbar/StatusBar  -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <!--  Secondary/Accent: vibrant green for buttons, FABs, switches  -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <!--  Background & Surface  -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <!--  Status bar: same dark green as toolbar for seamless look  -->
        <item name="android:statusBarColor">@color/primary_variant</item>
        <item name="android:navigationBarColor">@color/bottom_nav_bg</item>
        <!--  Default text colors  -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <!--  TextInputLayout (Material outlined style) uses these  -->
        <item name="colorError">@color/aqi_hazardous</item>
        <item name="colorOnError">@color/on_primary</item>
    </style>
    <!--  ═══ LOGIN SCREEN — Special full-dark theme ═══
             Login is the only screen with entirely dark background.
             It's like a "curtain" that opens into the light app.  -->
    <style name="Theme.AirBusQuest.Login" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <item name="android:colorBackground">@color/primary</item>
        <item name="colorSurface">@color/primary</item>
        <item name="android:statusBarColor">@color/primary_variant</item>
        <item name="android:navigationBarColor">@color/primary</item>
        <item name="android:textColorPrimary">@color/text_on_dark</item>
        <item name="android:textColorSecondary">@color/text_on_dark_secondary</item>
        <item name="android:textColorHint">@color/text_on_dark_secondary</item>
        <item name="colorError">@color/aqi_hazardous</item>
    </style>
    <!--  ═══ GAME OVER — Special dark dramatic theme ═══  -->
    <style name="Theme.AirBusQuest.GameOver" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:colorBackground">@color/game_over_bg</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:textColorPrimary">@color/text_on_dark</item>
    </style>
    <!--  ═══════════════════════════════════════════════════════
             REUSABLE COMPONENT STYLES
             ═══════════════════════════════════════════════════════  -->
    <!--  Dark toolbar that appears on all main screens  -->
    <style name="AirBusToolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/text_on_dark</item>
        <item name="subtitleTextColor">@color/text_on_dark_secondary</item>
        <item name="android:elevation">4dp</item>
    </style>
    <!--  PRIMARY BUTTON: Green filled capsule (for main actions)  -->
    <style name="AirBusButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="rippleColor">@color/ripple_dark</item>
    </style>
    <!--  SECONDARY BUTTON: Green outline capsule (for secondary actions)  -->
    <style name="AirBusButton.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>
    <!--  TEXT BUTTON: No background, just green text (for tertiary actions)  -->
    <style name="AirBusButton.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="rippleColor">@color/ripple_light</item>
    </style>
    <!--  DANGER BUTTON: Red filled (for destructive actions like clear data)  -->
    <style name="AirBusButton.Danger" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/aqi_hazardous</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="cornerRadius">24dp</item>
    </style>
    <!--  Card style: white, rounded, subtle shadow  -->
    <style name="AirBusCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
    </style>
    <!--  Input fields: Material outlined with green focus color  -->
    <style name="AirBusInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_focused</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
    <!--  Input fields for the login screen (white outline on dark bg)  -->
    <style name="AirBusInput.Login" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#99FFFFFF</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="android:textColorHint">#99FFFFFF</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
    <!--  Section title style used in Dashboard, Reports, etc.  -->
    <style name="AirBusSectionTitle">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingBottom">8dp</item>
    </style>
    <!--  Subtitle / secondary info text  -->
    <style name="AirBusSubtitle">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <!--  Big number display (HP value, AQI number)  -->
    <style name="AirBusBigNumber">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>